{
  "name": "pain001-generator",
  "version": "1.0.0",
  "description": "Express Backend – PAIN.001 XML Generator (v2009 / v2019)",
  "main": "dist/src/server.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "npm run build && node dist/src/server.js",
    "start:watch": "tsc --watch & nodemon dist/src/server.js",
    "test": "jest",
    "test:smoke": "jest --config jest.smoke.config.json"
  },
  "dependencies": {
    "express": "^4.22.1",
    "ibantools": "^4.5.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "xmlbuilder2": "^3.1.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.12",
    "@types/node": "^25.6.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "typescript": "^6.0.3"
  }
}
